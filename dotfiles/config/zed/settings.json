{
  "$schema": "zed://schemas/settings",

  // ===========================================================================
  // 0. PORTABLE / WORK-SAFE DEFAULTS
  //
  // This base config is safe to use on:
  // - your personal Mac
  // - a restricted work Mac
  // - repos you do not fully trust yet
  //
  // Personal AI and personal-only font/theme choices live in the profile below.
  // ===========================================================================

  "disable_ai": true,
  "show_edit_predictions": false,
  "edit_predictions": {
    "provider": "none",
    "mode": "subtle",
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "auto_update": false,

  "session": {
    "restore_unsaved_buffers": true,
    "trust_all_worktrees": false,
  },

  // ===========================================================================
  // 1. CORE EDITOR FEEL
  // ===========================================================================

  "base_keymap": "VSCode",
  "vim_mode": true,
  "helix_mode": false,

  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "use_regex_search": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 140,
  },

  "command_aliases": {
    "W": "w",
    "Wq": "wq",
    "WQ": "wq",
    "Q": "q",
    "Qa": "qa",
    "QA": "qa",
  },

  "autosave": "on_focus_change",
  "format_on_save": "on",
  "formatter": "auto",

  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,

  "tab_size": 2,
  "hard_tabs": false,

  "current_line_highlight": "all",
  "relative_line_numbers": "enabled",
  "cursor_blink": false,
  "scroll_beyond_last_line": "off",
  "vertical_scroll_margin": 6,

  "soft_wrap": "none",
  "preferred_line_length": 100,
  "wrap_guides": [100, 120],
  "show_wrap_guides": true,
  "show_whitespaces": "selection",

  "use_on_type_format": true,
  "use_auto_surround": true,
  "always_treat_brackets_as_autoclosed": false,

  // ===========================================================================
  // 2. VISUAL DESIGN
  //
  // Base uses built-in fonts/theme for portability.
  // Your MonoLisa/Catppuccin setup is in the personal profile below.
  // ===========================================================================

  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Espresso (Blur)",
  },

  "icon_theme": "Zed (Default)",

  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 16,
  "ui_font_weight": 400,

  "buffer_font_family": ".ZedMono",
  "buffer_font_size": 14,
  "buffer_font_weight": 400,
  "buffer_line_height": "comfortable",
  "buffer_font_features": {
    "calt": true,
  },

  "scrollbar": {
    "show": "auto",
  },

  "minimap": {
    "show": "never",
    "thumb": "hover",
    "thumb_border": "left_open",
  },

  // ===========================================================================
  // 3. COMPLETIONS / HINTS / INLINE UX
  //
  // Good LSP completion stays on.
  // AI prediction stays off in the base profile.
  // ===========================================================================

  "show_completions_on_input": true,
  "auto_signature_help": true,
  "show_signature_help_after_edits": true,
  "linked_edits": true,
  "inline_code_actions": true,

  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": false,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 500,
    "scroll_debounce_ms": 100,
  },

  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },

  // ===========================================================================
  // 4. PANELS / TABS / LAYOUT
  // ===========================================================================

  "centered_layout": {
    "left_padding": 0.12,
    "right_padding": 0.12,
  },

  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },

  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },

  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors",
    "show_close_button": "hover",
    "activate_on_close": "history",
    "close_position": "right",
  },

  "project_panel": {
    "auto_fold_dirs": false,
    "button": true,
    "dock": "right",
    "git_status": true,
    "indent_size": 18,
    "indent_guides": {
      "show": "always",
    },
    "sort_mode": "directories_first",
    "scrollbar": {
      "show": "auto",
      "horizontal_scroll": false,
    },
  },

  "git_panel": {
    "dock": "right",
  },

  "outline_panel": {
    "button": false,
    "dock": "right",
  },

  "collaboration_panel": {
    "button": false,
    "dock": "right",
  },

  "notification_panel": {
    "button": false,
    "dock": "left",
  },

  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },

  // ===========================================================================
  // 5. LANGUAGE DEFAULTS
  //
  // Rule:
  // - Keep global settings boring.
  // - Let each project decide Biome/Prettier/ESLint/Ruff/etc.
  // - Do not hard-code personal machine paths.
  // ===========================================================================

  "languages": {
    "Rust": {
      "format_on_save": "on",
      "formatter": "language_server",
      "preferred_line_length": 100,
      "inlay_hints": {
        "enabled": true,
        "show_background": false,
        "show_parameter_hints": false,
        "show_type_hints": true,
        "show_other_hints": true,
      },
    },

    "TypeScript": {
      "format_on_save": "on",
      "preferred_line_length": 100,
      "soft_wrap": "none",
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_type_hints": true,
        "show_other_hints": true,
        "show_background": false,
      },
    },

    "TSX": {
      "format_on_save": "on",
      "preferred_line_length": 100,
      "soft_wrap": "none",
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_type_hints": true,
        "show_other_hints": true,
        "show_background": false,
      },
    },

    "JavaScript": {
      "format_on_save": "on",
      "preferred_line_length": 100,
      "soft_wrap": "none",
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_type_hints": false,
        "show_other_hints": true,
        "show_background": false,
      },
    },

    "JSX": {
      "format_on_save": "on",
      "preferred_line_length": 100,
      "soft_wrap": "none",
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_type_hints": false,
        "show_other_hints": true,
        "show_background": false,
      },
    },

    "Python": {
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "language_servers": ["basedpyright", "ruff"],
      "preferred_line_length": 100,
      "soft_wrap": "none",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_type_hints": true,
        "show_other_hints": true,
        "show_background": false,
      },
    },

    "JSON": {
      "format_on_save": "on",
      "formatter": "language_server",
      "tab_size": 2,
    },

    "JSONC": {
      "format_on_save": "on",
      "formatter": "language_server",
      "tab_size": 2,
    },

    "Markdown": {
      "format_on_save": "on",
      "soft_wrap": "bounded",
      "preferred_line_length": 100,
      "remove_trailing_whitespace_on_save": false,
      "ensure_final_newline_on_save": true,
    },

    "YAML": {
      "format_on_save": "on",
      "tab_size": 2,
    },

    "TOML": {
      "format_on_save": "on",
      "tab_size": 2,
    },
  },

  // ===========================================================================
  // 6. LANGUAGE SERVER CONFIG
  //
  // No absolute /Users/... paths here.
  // No mandatory nightly Rust.
  // No global Biome hijack.
  // ===========================================================================

  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "rust": {
          "analyzerTargetDir": true,
        },
        "inlayHints": {
          "maxLength": null,
          "closureReturnTypeHints": {
            "enable": "always",
          },
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
        },
      },
    },

    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "inlayHints": {
            "callArgumentNames": false,
          },
        },
      },
    },

    "tailwindcss-language-server": {
      "settings": {
        "classAttributes": ["class", "className", "ngClass", "styles"],
        "classFunctions": ["cva", "cx", "cn", "clsx", "tw", "tv"],
      },
    },
  },

  // ===========================================================================
  // 7. TERMINAL
  //
  // Portable. No personal-only shell assumptions.
  // ===========================================================================

  "terminal": {
    "button": true,
    "copy_on_select": true,
    "blinking": "off",
    "line_height": "standard",
    "working_directory": "current_project_directory",
    "detect_venv": {
      "on": {
        "directories": [".venv", "venv", ".env", "env"],
        "activate_script": "default",
      },
    },
    "env": {
      "EDITOR": "zed --wait",
      "VISUAL": "zed --wait",
    },
  },

  // ===========================================================================
  // 8. FILE TYPES
  // ===========================================================================

  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["*.json"],
    "JSONC": ["*.jsonc", "*.code-snippets"],
  },

  // ===========================================================================
  // 9. FILE SCANNING
  //
  // Important: Zed says overriding file_scan_exclusions replaces the defaults,
  // so the default exclusions are repeated here before custom ones.
  // ===========================================================================

  "file_scan_exclusions": [
    // Zed defaults.
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",

    // JavaScript / TypeScript.
    "**/node_modules",
    "**/bower_components",
    "**/.next",
    "**/.nuxt",
    "**/.svelte-kit",
    "**/.astro",
    "**/.turbo",
    "**/.vercel",
    "**/.vite",
    "**/.parcel-cache",
    "**/storybook-static",

    // Build output.
    "**/dist",
    "**/build",
    "**/out",
    "**/coverage",
    "**/report",

    // Tests / caches.
    "**/.tap",
    "**/.nyc_output",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/.mypy_cache",
    "**/.tox",
    "**/.cache",

    // Python / local envs.
    "**/.venv",
    "**/venv",

    // Rust.
    "**/target",

    // Tooling noise.
    "**/.husky",
    "**/.vscode",
    "**/.vscode-test",
    "**/.direnv",
  ],

  // ===========================================================================
  // 10. PERSONAL MAC PROFILE
  //
  // Keep the base work-safe.
  // Switch to this profile only on your personal Mac.
  // ===========================================================================

  "profiles": {
    "Personal Mac": {
      "settings": {
        "auto_update": true,

        "disable_ai": false,
        "show_edit_predictions": true,
        "edit_predictions": {
          "provider": "zed",
          "mode": "subtle",
        },

        "theme": "Catppuccin Espresso (Blur) [Heavy]",

        "buffer_font_family": "MonoLisaVariable Nerd Font",
        "terminal": {
          "font_family": "MonoLisaVariable Nerd Font",
        },

        "agent": {
          "dock": "left",
          "favorite_models": [],
          "model_parameters": [],
        },
      },
    },
  },
}
